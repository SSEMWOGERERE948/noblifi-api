PORT=8080
APP_ENV=development
PUBLIC_API_BASE_URL=http://localhost:8080
NOBLIFI_PROVISIONING_BASE_URL=http://localhost:8080/api/v1/provisioning
DATABASE_URL=postgres://noblifi:noblifi@localhost:5432/noblifi?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret

# RADIUS must run on a VPS or another host that accepts UDP 1812/1813.
# When WireGuard is enabled, use the VPS tunnel IP here.
NOBLIFI_RADIUS_SERVER=10.77.0.1
NOBLIFI_RADIUS_SECRET=noblifi
NOBLIFI_RADIUS_AUTH_PORT=1812
NOBLIFI_RADIUS_ACCT_PORT=1813

# WireGuard VPS. Run scripts/setup-wireguard-vps.sh on the VPS first, then
# paste the printed public key below. The endpoint is the VPS public IP or DNS.
NOBLIFI_WIREGUARD_ENABLED=false
NOBLIFI_WIREGUARD_ENDPOINT=203.0.113.10
NOBLIFI_WIREGUARD_PORT=51820
NOBLIFI_WIREGUARD_PUBLIC_KEY=
NOBLIFI_WIREGUARD_INTERFACE=wg0
NOBLIFI_WIREGUARD_SERVER_IP=10.77.0.1
NOBLIFI_WIREGUARD_SUBNET=10.77.0.0/24
NOBLIFI_WIREGUARD_KEEPALIVE=25

# MikroTik defaults used by generated service scripts.
NOBLIFI_ROUTER_IDENTITY_PREFIX=NobliFi
NOBLIFI_ROUTER_API_USERNAME=noblifi-api
NOBLIFI_ROUTER_API_PASSWORD=replace-with-a-strong-router-api-password
NOBLIFI_HOTSPOT_BRIDGE=br-hotspot
NOBLIFI_STAFF_BRIDGE=br-staff
NOBLIFI_POS_BRIDGE=br-pos
NOBLIFI_CCTV_BRIDGE=br-cctv
NOBLIFI_HOTSPOT_SUBNET=10.10.10.0/24
NOBLIFI_HOTSPOT_GATEWAY=10.10.10.1/24
NOBLIFI_HOTSPOT_POOL=10.10.10.10-10.10.10.254
NOBLIFI_STAFF_SUBNET=10.20.20.0/24
NOBLIFI_STAFF_GATEWAY=10.20.20.1/24
NOBLIFI_STAFF_POOL=10.20.20.10-10.20.20.254
NOBLIFI_POS_SUBNET=10.30.30.0/24
NOBLIFI_POS_GATEWAY=10.30.30.1/24
NOBLIFI_POS_POOL=10.30.30.10-10.30.30.254
NOBLIFI_CCTV_SUBNET=10.40.40.0/24
NOBLIFI_CCTV_GATEWAY=10.40.40.1/24
NOBLIFI_CCTV_POOL=10.40.40.10-10.40.40.254
NOBLIFI_HOTSPOT_DNS_NAME=login.noblifi.local
NOBLIFI_HOTSPOT_PORTAL_NAME=NobliFi WiFi
NOBLIFI_HOTSPOT_WALLED_GARDEN_HOSTS=noblifi-frontend.vercel.app,noblifi.ew.r.appspot.com
NOBLIFI_DISABLE_WWW_SERVICE=true
NOBLIFI_ENABLE_API_SERVICE=true
NOBLIFI_ENABLE_API_SSL_SERVICE=true
