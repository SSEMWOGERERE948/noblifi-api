PORT=3000
PUBLIC_BASE_URL=https://billing.example.com
DATABASE_PATH=./noblifi.db

# Used inside generated MikroTik scripts.
# Public IPv4 of a VM/server that accepts UDP 1812 and 1813.
# Google App Engine and Vercel cannot receive RADIUS UDP traffic.
BILLING_RADIUS_ADDRESS=203.0.113.10
BILLING_PORTAL_HOST=billing.example.com
RADIUS_EMBEDDED=true
MIKROTIK_TIMEOUT_MS=5000

# Optional default account/router seed.
DEFAULT_ACCOUNT_NAME=Demo WiFi
DEFAULT_ACCOUNT_SLUG=demo
DEFAULT_SUPPORT_PHONE=0700000000
DEFAULT_ROUTER_NAME=Demo MikroTik
DEFAULT_ROUTER_HOST=192.168.88.1
DEFAULT_ROUTER_USER=admin
DEFAULT_ROUTER_PASS=
DEFAULT_RADIUS_SECRET=noblifi

# Pesapal payments.
# Sandbox: https://cybqa.pesapal.com/pesapalv3/api
# Live:    https://pay.pesapal.com/v3/api
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3/api
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=
PESAPAL_CURRENCY=UGX
PESAPAL_NET_PERCENT=100

RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
